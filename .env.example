# Supabase — get these from supabase.com → Project Settings → API
PUBLIC_SUPABASE_URL=https://your-project.supabase.co
PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Resend — get from resend.com → API Keys
RESEND_API_KEY=re_xxxxxxxx

# Admin access — comma-separated list of allowed admin emails
ADMIN_EMAILS=veronica@blissfulbutterflyyoga.com

# Site URL
PUBLIC_SITE_URL=https://blissfulbutterflyyoga.com
