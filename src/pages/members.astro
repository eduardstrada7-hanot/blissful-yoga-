---
import Base from '../layouts/Base.astro';
---

<Base
  title="Members Area — Your Classes & On Demand"
  description="Access your live class credits, Yoga On Demand library, and member resources."
  noindex={true}
>
  <!-- Shown only to logged-in members via Memberstack -->
  <div data-ms-content="members">

    <!-- Hero -->
    <section style="background:var(--color-sand);padding:64px 0 0;">
      <div class="container" style="max-width:800px;padding-bottom:48px;">
        <p style="font-size:0.75rem;font-weight:700;letter-spacing:0.12em;text-transform:uppercase;color:var(--color-rose);margin-bottom:0.5rem;">Members area</p>
        <h1 style="font-size:clamp(2rem,5vw,3rem);margin-bottom:0.75rem;">Welcome back</h1>
        <p style="font-size:1rem;line-height:1.7;color:var(--color-ink);opacity:0.75;">Your classes, recordings, and community — all in one place.</p>
      </div>
    </section>

    <!-- Quick actions -->
    <section style="background:var(--color-sand);padding:0 0 80px;">
      <div class="container">
        <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(260px,1fr));gap:1.25rem;">

          <!-- Book a live class -->
          <div style="background:var(--color-cream);border:1px solid var(--color-line);border-radius:4px;padding:1.75rem;display:flex;flex-direction:column;gap:1rem;">
            <div style="width:44px;height:44px;border-radius:50%;background:rgba(91,58,91,0.1);display:flex;align-items:center;justify-content:center;">
              <svg width="22" height="22" viewBox="0 0 22 22" fill="none" aria-hidden="true">
                <rect x="2" y="4" width="18" height="16" rx="2" stroke="var(--color-plum)" stroke-width="1.5"/>
                <path d="M2 9h18" stroke="var(--color-plum)" stroke-width="1.5"/>
                <path d="M7 2v4M15 2v4" stroke="var(--color-plum)" stroke-width="1.5" stroke-linecap="round"/>
              </svg>
            </div>
            <div>
              <h2 style="font-size:1.1rem;font-weight:700;margin:0 0 0.35rem;">Book a live class</h2>
              <p style="font-size:0.875rem;color:var(--color-ink);opacity:0.65;margin:0;line-height:1.6;">Reserve your spot in this week's live sessions.</p>
            </div>
            <a href="/offerings/classes" class="btn-primary" style="margin-top:auto;text-align:center;">View schedule</a>
          </div>

          <!-- Yoga On Demand -->
          <div style="background:var(--color-cream);border:1px solid var(--color-line);border-radius:4px;padding:1.75rem;display:flex;flex-direction:column;gap:1rem;">
            <div style="width:44px;height:44px;border-radius:50%;background:rgba(91,58,91,0.1);display:flex;align-items:center;justify-content:center;">
              <svg width="22" height="22" viewBox="0 0 22 22" fill="none" aria-hidden="true">
                <rect x="2" y="4" width="18" height="14" rx="2" stroke="var(--color-plum)" stroke-width="1.5"/>
                <path d="M9 9l5 2.5L9 14V9z" fill="var(--color-plum)"/>
              </svg>
            </div>
            <div>
              <h2 style="font-size:1.1rem;font-weight:700;margin:0 0 0.35rem;">Yoga On Demand</h2>
              <p style="font-size:0.875rem;color:var(--color-ink);opacity:0.65;margin:0;line-height:1.6;">Your full library of recorded classes, available any time.</p>
            </div>
            <a href="/on-demand" class="btn-primary" style="margin-top:auto;text-align:center;">Open library</a>
          </div>

          <!-- Soulhood Circle -->
          <div style="background:var(--color-cream);border:1px solid var(--color-line);border-radius:4px;padding:1.75rem;display:flex;flex-direction:column;gap:1rem;">
            <div style="width:44px;height:44px;border-radius:50%;background:rgba(192,132,120,0.12);display:flex;align-items:center;justify-content:center;">
              <svg width="22" height="22" viewBox="0 0 22 22" fill="none" aria-hidden="true">
                <circle cx="7.5" cy="8" r="3.5" stroke="var(--color-rose)" stroke-width="1.5"/>
                <circle cx="14.5" cy="8" r="3.5" stroke="var(--color-rose)" stroke-width="1.5"/>
                <path d="M2 19c0-3 2.5-5 5.5-5h7c3 0 5.5 2 5.5 5" stroke="var(--color-rose)" stroke-width="1.5" stroke-linecap="round"/>
              </svg>
            </div>
            <div>
              <h2 style="font-size:1.1rem;font-weight:700;margin:0 0 0.35rem;">Soulhood Circle</h2>
              <p style="font-size:0.875rem;color:var(--color-ink);opacity:0.65;margin:0;line-height:1.6;">Quarterly burn ceremony — your next one is included free.</p>
            </div>
            <a href="/offerings/soulhood" class="btn-outline" style="margin-top:auto;text-align:center;">Learn more</a>
          </div>

        </div>
      </div>
    </section>

    <hr class="section-divider" />

    <!-- On Demand preview -->
    <section style="padding:64px 0;">
      <div class="container">
        <div style="display:flex;align-items:baseline;justify-content:space-between;flex-wrap:wrap;gap:1rem;margin-bottom:2rem;">
          <h2 style="font-size:clamp(1.5rem,3vw,2rem);">Recent On Demand classes</h2>
          <a href="/on-demand" style="font-size:0.875rem;font-weight:600;color:var(--color-rose);">View all →</a>
        </div>

        <!-- Placeholder cards — replace with real VOD embed/library when wired -->
        <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(260px,1fr));gap:1.25rem;">
          {[
            { title: "Sleepy Orange Evening", style: "Gentle", length: "60 min", desc: "A slow, soft practice to unwind the day." },
            { title: "Clouded Yellow Morning", style: "Vin Yin", length: "75 min", desc: "Vinyasa warmth followed by long Yin holds." },
            { title: "Silvery Blue Morning", style: "Yin", length: "45 min", desc: "A short, stilling Yin practice to start the day." },
          ].map(({ title, style, length, desc }) => (
            <div style="background:var(--color-cream);border:1px solid var(--color-line);border-radius:4px;overflow:hidden;">
              <div style="background:var(--color-sand);height:140px;display:flex;align-items:center;justify-content:center;">
                <svg width="48" height="48" viewBox="0 0 48 48" fill="none" aria-hidden="true">
                  <circle cx="24" cy="24" r="20" fill="var(--color-plum)" opacity="0.1"/>
                  <path d="M19 16l14 8-14 8V16z" fill="var(--color-plum)" opacity="0.6"/>
                </svg>
              </div>
              <div style="padding:1.25rem;">
                <p style="font-size:0.75rem;font-weight:600;letter-spacing:0.08em;text-transform:uppercase;color:var(--color-rose);margin:0 0 0.35rem;">{style} · {length}</p>
                <h3 style="font-size:1rem;font-weight:700;margin:0 0 0.5rem;">{title}</h3>
                <p style="font-size:0.85rem;color:var(--color-ink);opacity:0.65;margin:0 0 1rem;line-height:1.5;">{desc}</p>
                <button style="font-size:0.875rem;font-weight:600;color:var(--color-plum);background:none;border:none;cursor:pointer;padding:0;font-family:var(--font-body);">Watch →</button>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <hr class="section-divider" />

    <!-- Account section -->
    <section style="padding:64px 0;background:var(--color-cream);">
      <div class="container" style="max-width:600px;">
        <h2 style="font-size:1.5rem;margin-bottom:1.5rem;">Your account</h2>
        <div style="display:flex;flex-direction:column;gap:0.75rem;">
          <div style="display:flex;align-items:center;justify-content:space-between;padding:1rem 1.25rem;background:var(--color-sand);border-radius:4px;flex-wrap:wrap;gap:0.75rem;">
            <div>
              <p style="font-size:0.8rem;font-weight:600;text-transform:uppercase;letter-spacing:0.08em;color:var(--color-ink);opacity:0.5;margin:0 0 0.2rem;">Membership</p>
              <p style="font-size:0.95rem;font-weight:600;margin:0;">Managed via Memberstack</p>
            </div>
            <a href="https://app.memberstack.com" target="_blank" rel="noopener noreferrer" style="font-size:0.875rem;font-weight:600;color:var(--color-plum);">Manage plan →</a>
          </div>

          <div style="display:flex;align-items:center;justify-content:space-between;padding:1rem 1.25rem;background:var(--color-sand);border-radius:4px;flex-wrap:wrap;gap:0.75rem;">
            <div>
              <p style="font-size:0.8rem;font-weight:600;text-transform:uppercase;letter-spacing:0.08em;color:var(--color-ink);opacity:0.5;margin:0 0 0.2rem;">Questions?</p>
              <p style="font-size:0.95rem;font-weight:600;margin:0;">Contact Veronica</p>
            </div>
            <a href="/contact" style="font-size:0.875rem;font-weight:600;color:var(--color-plum);">Get in touch →</a>
          </div>
        </div>

        <div style="margin-top:2rem;padding-top:2rem;border-top:1px solid var(--color-line);display:flex;align-items:center;gap:1rem;flex-wrap:wrap;">
          <button
            data-ms-action="logout"
            style="font-size:0.875rem;font-weight:500;color:var(--color-ink);opacity:0.6;background:none;border:1px solid var(--color-line);border-radius:4px;cursor:pointer;padding:0.5rem 1rem;font-family:var(--font-body);transition:opacity 150ms ease;"
            onmouseover="this.style.opacity='1'"
            onmouseout="this.style.opacity='0.6'"
            aria-label="Log out of your account"
          >
            Log out
          </button>
          <p style="font-size:0.8rem;color:var(--color-ink);opacity:0.4;margin:0;">You'll be redirected to the home page.</p>
        </div>
      </div>
    </section>

  </div><!-- end data-ms-content="members" -->

  <!-- Shown only to logged-OUT visitors -->
  <div data-ms-content="!members">
    <section style="padding:120px 0;background:var(--color-sand);text-align:center;">
      <div class="container" style="max-width:520px;">
        <svg width="56" height="56" viewBox="0 0 56 56" fill="none" aria-hidden="true" style="margin:0 auto 1.5rem;">
          <circle cx="28" cy="28" r="27" stroke="var(--color-plum)" stroke-width="1.5" opacity="0.25"/>
          <path d="M28 16a6 6 0 1 1 0 12 6 6 0 0 1 0-12zm0 14c-6.63 0-12 3.36-12 5v2h24v-2c0-1.64-5.37-5-12-5z" fill="var(--color-plum)" opacity="0.5"/>
        </svg>
        <h1 style="font-size:clamp(1.8rem,4vw,2.5rem);margin-bottom:0.75rem;">Members only</h1>
        <p style="font-size:1rem;line-height:1.7;color:var(--color-ink);opacity:0.7;margin-bottom:2rem;">
          This area is for Blissful Butterfly Yoga members. Log in below, or join a membership plan to get access.
        </p>
        <div style="display:flex;flex-direction:column;gap:1rem;align-items:center;">
          <button
            data-ms-action="login"
            class="btn-primary"
            style="min-width:220px;"
            aria-label="Log in to your member account"
          >
            Log in to your account
          </button>
          <a href="/packages" class="btn-outline" style="min-width:220px;text-align:center;" aria-label="View membership plans">
            View membership plans
          </a>
        </div>
        <p style="margin-top:1.5rem;font-size:0.8rem;color:var(--color-ink);opacity:0.45;">
          Sign up and log in with Google, Facebook, or email
        </p>
      </div>
    </section>
  </div><!-- end data-ms-content="!members" -->

</Base>
