---
import Base from '../layouts/Base.astro';

const plans = [
  {
    id: "caterpillar",
    msId: "YOUR_CATERPILLAR_PLAN_ID",   // Replace with Memberstack plan ID
    name: "Caterpillar Crew",
    emoji: "🐛",
    price: 70,
    period: "month",
    tagline: "Perfect for starting your practice",
    features: [
      "5 live online yoga classes per month",
      "Unlimited Yoga On Demand access",
      "Free quarterly Soulhood Circle Burn Ceremony",
      "Members-only community",
    ],
    note: "Classes reset monthly",
    cta: "Start with Caterpillar",
    featured: false,
  },
  {
    id: "chrysalis",
    msId: "YOUR_CHRYSALIS_PLAN_ID",     // Replace with Memberstack plan ID
    name: "Chrysalis Crew",
    emoji: "🦋",
    price: 117,
    period: "month",
    tagline: "Best value — for the committed student",
    features: [
      "9 live online yoga classes per month",
      "Unlimited Yoga On Demand access",
      "Free quarterly Soulhood Circle Burn Ceremony",
      "Members-only community",
      "Priority booking for special events",
    ],
    note: "Classes reset monthly",
    cta: "Start with Chrysalis",
    featured: true,
  },
  {
    id: "ondemand",
    msId: "YOUR_ONDEMAND_PLAN_ID",      // Replace with Memberstack plan ID
    name: "30 Days On Demand",
    emoji: "▶️",
    price: 55,
    period: "month",
    tagline: "Flexible — practice on your own schedule",
    features: [
      "Unlimited Yoga On Demand access",
      "All class styles: Gentle, Yin, Vin Yin & more",
      "New classes added regularly",
      "7-day free trial",
    ],
    note: "7-day free trial included",
    cta: "Try free for 7 days",
    featured: false,
  },
];
---

<Base
  title="Membership Plans — Yoga Classes & On Demand"
  description="Join Blissful Butterfly Yoga as a member. Choose from Caterpillar Crew ($70/mo), Chrysalis Crew ($117/mo), or 30 Days On Demand ($55/mo). All plans include Yoga On Demand access."
>
  <!-- Hero -->
  <section style="background:var(--color-sand);padding:80px 0 0;">
    <div class="container" style="max-width:800px;padding-bottom:60px;text-align:center;">
      <p style="font-size:0.75rem;font-weight:700;letter-spacing:0.12em;text-transform:uppercase;color:var(--color-rose);margin-bottom:0.5rem;" class="fade-in">Membership</p>
      <h1 style="font-size:clamp(2.4rem,6vw,3.5rem);margin-bottom:1rem;" class="fade-in">Join the community</h1>
      <p style="font-size:1.05rem;line-height:1.75;color:var(--color-ink);opacity:0.75;max-width:560px;margin:0 auto;" class="fade-in">
        Unlimited On Demand classes, live weekly sessions, and a community that actually shows up for each other. Cancel anytime.
      </p>
    </div>
  </section>

  <!-- Pricing cards -->
  <section style="background:var(--color-sand);padding:0 0 96px;">
    <div class="container">
      <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(280px,1fr));gap:1.5rem;align-items:start;">
        {plans.map((plan) => (
          <div
            class="fade-in"
            style={`background:var(--color-cream);border:${plan.featured ? '2px solid var(--color-plum)' : '1px solid var(--color-line)'};border-radius:4px;overflow:hidden;display:flex;flex-direction:column;position:relative;`}
          >
            {plan.featured && (
              <div style="background:var(--color-plum);color:var(--color-cream);text-align:center;padding:0.4rem;font-size:0.75rem;font-weight:700;letter-spacing:0.1em;text-transform:uppercase;">
                Best Value
              </div>
            )}

            <div style="padding:2rem;flex:1;display:flex;flex-direction:column;gap:1.25rem;">
              <!-- Header -->
              <div>
                <p style="font-size:1.5rem;margin:0 0 0.25rem;" aria-hidden="true">{plan.emoji.replace('🐛','').replace('🦋','').replace('▶️','')}</p>
                <h2 style="font-size:1.5rem;font-weight:700;margin:0 0 0.25rem;">{plan.name}</h2>
                <p style="font-size:0.85rem;color:var(--color-ink);opacity:0.6;margin:0;">{plan.tagline}</p>
              </div>

              <!-- Price -->
              <div style="display:flex;align-items:baseline;gap:0.25rem;">
                <span style="font-family:var(--font-display);font-size:3rem;font-weight:700;color:var(--color-plum);line-height:1;">${plan.price}</span>
                <span style="font-size:0.9rem;color:var(--color-ink);opacity:0.6;">/{plan.period}</span>
              </div>

              <!-- Features -->
              <ul style="list-style:none;padding:0;margin:0;display:flex;flex-direction:column;gap:0.625rem;flex:1;">
                {plan.features.map((f) => (
                  <li style="display:flex;gap:0.625rem;align-items:flex-start;font-size:0.9rem;color:var(--color-ink);line-height:1.5;">
                    <svg width="16" height="16" viewBox="0 0 16 16" fill="none" style="flex-shrink:0;margin-top:2px;" aria-hidden="true">
                      <circle cx="8" cy="8" r="7" fill="var(--color-plum)" opacity="0.12"/>
                      <path d="M4.5 8l2.5 2.5 4.5-4.5" stroke="var(--color-plum)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                    {f}
                  </li>
                ))}
              </ul>

              {plan.note && (
                <p style="font-size:0.78rem;color:var(--color-ink);opacity:0.45;font-style:italic;margin:0;">{plan.note}</p>
              )}

              <!-- CTA — Memberstack signup button -->
              <button
                data-ms-action="signup"
                data-ms-plan={plan.msId}
                style={`width:100%;padding:0.875rem;border-radius:4px;font-size:0.9375rem;font-weight:600;font-family:var(--font-body);cursor:pointer;transition:background 150ms ease,border-color 150ms ease;${plan.featured ? 'background:var(--color-plum);color:var(--color-cream);border:2px solid var(--color-plum);' : 'background:transparent;color:var(--color-plum);border:2px solid var(--color-plum);'}`}
                onmouseover={plan.featured ? "this.style.background='var(--color-plum-dark)';this.style.borderColor='var(--color-plum-dark)'" : "this.style.background='var(--color-plum)';this.style.color='var(--color-cream)'"}
                onmouseout={plan.featured ? "this.style.background='var(--color-plum)';this.style.borderColor='var(--color-plum)'" : "this.style.background='transparent';this.style.color='var(--color-plum)'"}
                aria-label={`Sign up for ${plan.name} — $${plan.price} per month`}
              >
                {plan.cta}
              </button>
            </div>
          </div>
        ))}
      </div>

      <!-- Policy note -->
      <p style="text-align:center;margin-top:2rem;font-size:0.8rem;color:var(--color-ink);opacity:0.5;">
        All sales are final. Cancel your subscription anytime from your member dashboard.
      </p>
    </div>
  </section>

  <hr class="section-divider" />

  <!-- Already a member -->
  <section style="padding:64px 0;background:var(--color-cream);">
    <div class="container" style="max-width:600px;text-align:center;">
      <p style="font-size:1rem;color:var(--color-ink);opacity:0.7;margin-bottom:1rem;" class="fade-in">Already a member?</p>
      <button
        data-ms-action="login"
        class="btn-primary fade-in"
        style="display:inline-flex;align-items:center;gap:0.5rem;"
        aria-label="Log in to your member account"
      >
        <svg width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true"><path d="M9 2a4 4 0 1 1 0 8A4 4 0 0 1 9 2zm0 10c-4 0-7 2-7 3v1h14v-1c0-1-3-3-7-3z" fill="currentColor"/></svg>
        Log in to your account
      </button>

      <!-- Social login options label -->
      <p style="margin-top:1.5rem;font-size:0.8rem;color:var(--color-ink);opacity:0.5;" class="fade-in">
        Sign up and log in with Google, Facebook, or email
      </p>
      <div style="display:flex;justify-content:center;gap:1rem;margin-top:0.75rem;flex-wrap:wrap;" class="fade-in">
        <!-- Visual indicators only — Memberstack handles the actual OAuth -->
        {[
          { name: "Google", icon: `<svg width="20" height="20" viewBox="0 0 24 24" aria-hidden="true"><path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/><path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/><path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l3.66-2.84z" fill="#FBBC05"/><path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/></svg>` },
          { name: "Facebook", icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="#1877F2" aria-hidden="true"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>` },
          { name: "Email", icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--color-ink)" stroke-width="2" aria-hidden="true"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>` },
        ].map(({ name, icon }) => (
          <div style="display:flex;align-items:center;gap:0.4rem;padding:0.4rem 0.875rem;border:1px solid var(--color-line);border-radius:4px;font-size:0.8rem;color:var(--color-ink);opacity:0.6;" set:html={`${icon}<span>${name}</span>`} />
        ))}
      </div>
    </div>
  </section>

  <hr class="section-divider" />

  <!-- FAQ -->
  <section style="padding:64px 0;">
    <div class="container" style="max-width:700px;">
      <h2 style="font-size:clamp(1.6rem,3vw,2rem);margin-bottom:2rem;" class="fade-in">Membership questions</h2>
      <dl style="display:flex;flex-direction:column;">
        {[
          ["Can I cancel anytime?", "Yes. You can cancel your membership from your member dashboard at any time. You'll retain access until the end of your current billing period."],
          ["Do unused classes roll over?", "No — live class credits reset at the start of each billing month. Yoga On Demand access is unlimited and always available."],
          ["What's included in Yoga On Demand?", "A growing library of recorded classes across all styles — Gentle, Yin, Vin Yin, Wild Card, and more. New classes added regularly."],
          ["What is the Soulhood Circle Burn Ceremony?", "A quarterly group gathering facilitated by Veronica — a ritual of release, intention-setting, and community. Included free in Caterpillar and Chrysalis plans."],
          ["Can I upgrade or downgrade my plan?", "Yes. You can switch plans from your member dashboard at any time. Changes take effect at the next billing cycle."],
          ["Is there a free trial?", "The 30 Days On Demand plan includes a 7-day free trial. No credit card charge until day 8."],
        ].map(([q, a], i) => (
          <div class="faq-item fade-in" style="border-bottom:1px solid var(--color-line);">
            <dt>
              <button class="faq-btn" aria-expanded="false" aria-controls={`pkg-faq-${i}`} style="width:100%;display:flex;align-items:center;justify-content:space-between;padding:1.125rem 0;background:none;border:none;cursor:pointer;text-align:left;font-family:var(--font-body);font-size:1rem;font-weight:600;color:var(--color-ink);gap:1rem;">
                {q}
                <svg class="faq-chevron" width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true" style="flex-shrink:0;transition:transform 200ms ease;"><path d="M4 7l5 5 5-5" stroke="var(--color-plum)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
              </button>
            </dt>
            <dd id={`pkg-faq-${i}`} style="display:none;padding:0 0 1.125rem;font-size:0.95rem;line-height:1.7;color:var(--color-ink);opacity:0.8;">{a}</dd>
          </div>
        ))}
      </dl>
    </div>
  </section>
</Base>

<script>
  document.querySelectorAll<HTMLButtonElement>('.faq-btn').forEach((btn) => {
    btn.addEventListener('click', () => {
      const expanded = btn.getAttribute('aria-expanded') === 'true';
      const answerId = btn.getAttribute('aria-controls')!;
      const answer = document.getElementById(answerId)!;
      const chevron = btn.querySelector<SVGElement>('.faq-chevron')!;
      btn.setAttribute('aria-expanded', String(!expanded));
      answer.style.display = expanded ? 'none' : 'block';
      chevron.style.transform = expanded ? 'rotate(0deg)' : 'rotate(180deg)';
    });
  });
</script>
