---
export const prerender = false;
import { createServerSupabase } from '../../lib/supabase/server';

let sent = false;
let error = '';

if (Astro.request.method === 'POST') {
  const form = await Astro.request.formData();
  const email = form.get('email')?.toString() ?? '';
  const supabase = createServerSupabase(Astro.request, Astro.cookies);
  const { error: err } = await supabase.auth.resetPasswordForEmail(email, {
    redirectTo: `${import.meta.env.PUBLIC_SITE_URL}/admin/reset-password`,
  });
  if (err) error = err.message;
  else sent = true;
}

// Handle the token from email link
const access_token = Astro.url.searchParams.get('access_token');
let resetMode = !!access_token;
let resetSuccess = false;
let resetError = '';

if (resetMode && Astro.request.method === 'POST') {
  const form = await Astro.request.formData();
  const newPassword = form.get('new_password')?.toString() ?? '';
  const supabase = createServerSupabase(Astro.request, Astro.cookies);
  const { error: err } = await supabase.auth.updateUser({ password: newPassword });
  if (err) resetError = err.message;
  else resetSuccess = true;
}
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Reset Password — Blissful Butterfly Yoga Admin</title>
  <meta name="robots" content="noindex, nofollow" />
</head>
<body style="margin:0;font-family:'Inter Tight',sans-serif;background:#E8DFD0;min-height:100vh;display:flex;align-items:center;justify-content:center;padding:2rem;">
  <div style="background:#fff;border:1px solid #D9CDB8;border-radius:6px;padding:2.5rem;width:100%;max-width:380px;">
    <h1 style="font-size:1.2rem;font-weight:700;margin-bottom:0.5rem;">Reset password</h1>

    {sent ? (
      <p style="font-size:0.9rem;color:#065f46;background:#d1fae5;padding:0.75rem 1rem;border-radius:4px;">
        Check your email for the reset link.
      </p>
    ) : resetSuccess ? (
      <div>
        <p style="font-size:0.9rem;color:#065f46;background:#d1fae5;padding:0.75rem 1rem;border-radius:4px;margin-bottom:1rem;">Password updated! You can now log in.</p>
        <a href="/admin/login" style="font-weight:600;color:#5B3A5B;">← Back to login</a>
      </div>
    ) : resetMode ? (
      <form method="post" style="display:flex;flex-direction:column;gap:1rem;">
        {resetError && <p style="color:#991b1b;font-size:0.875rem;">{resetError}</p>}
        <div>
          <label style="display:block;font-size:0.8rem;font-weight:600;margin-bottom:0.375rem;">New password</label>
          <input type="password" name="new_password" required minlength="8" style="width:100%;padding:0.625rem 0.875rem;border:1px solid #D9CDB8;border-radius:4px;font-size:0.9rem;font-family:inherit;" />
        </div>
        <button type="submit" style="padding:0.75rem;background:#5B3A5B;color:#fff;border:none;border-radius:4px;font-weight:600;cursor:pointer;font-family:inherit;">Set new password</button>
      </form>
    ) : (
      <form method="post" style="display:flex;flex-direction:column;gap:1rem;">
        {error && <p style="color:#991b1b;font-size:0.875rem;">{error}</p>}
        <p style="font-size:0.875rem;opacity:0.7;margin:0;">Enter your admin email and we'll send a reset link.</p>
        <div>
          <label style="display:block;font-size:0.8rem;font-weight:600;margin-bottom:0.375rem;">Email</label>
          <input type="email" name="email" required autocomplete="email" style="width:100%;padding:0.625rem 0.875rem;border:1px solid #D9CDB8;border-radius:4px;font-size:0.9rem;font-family:inherit;" />
        </div>
        <button type="submit" style="padding:0.75rem;background:#5B3A5B;color:#fff;border:none;border-radius:4px;font-weight:600;cursor:pointer;font-family:inherit;">Send reset link</button>
        <a href="/admin/login" style="text-align:center;font-size:0.8rem;color:#5B3A5B;text-decoration:underline;">← Back to login</a>
      </form>
    )}
  </div>
</body>
</html>
