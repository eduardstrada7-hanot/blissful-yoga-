---
export const prerender = false;
import AdminLayout from '../../../layouts/AdminLayout.astro';
import { createAdminClient } from '../../../lib/supabase/admin';

const db = createAdminClient();

// Handle delete
if (Astro.request.method === 'POST') {
  const form = await Astro.request.formData();
  const action = form.get('action')?.toString();
  const id = form.get('id')?.toString();
  if (action === 'delete' && id) {
    await db.from('blog_posts').delete().eq('id', id);
  } else if (action === 'unpublish' && id) {
    await db.from('blog_posts').update({ status: 'draft' }).eq('id', id);
  }
  return Astro.redirect('/admin/blog');
}

const { data: posts = [] } = await db.from('blog_posts').select('id,title,slug,status,published_at,created_at,updated_at').order('updated_at', { ascending: false });

function fmtDate(d: string) {
  return new Date(d).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
}
---

<AdminLayout title="Blog Posts" active="blog">
  <div class="section-head">
    <h2>All Posts ({posts.length})</h2>
    <a href="/admin/blog/new" class="btn btn-plum">+ New post</a>
  </div>

  <div class="card" style="overflow-x:auto;">
    {posts.length === 0 ? (
      <div class="empty-state">
        <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><path d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/></svg>
        <p>No blog posts yet. <a href="/admin/blog/new" style="color:var(--color-plum);text-decoration:underline;">Create your first post →</a></p>
      </div>
    ) : (
      <table class="data-table">
        <thead>
          <tr>
            <th>Title</th>
            <th>Status</th>
            <th>Published</th>
            <th>Updated</th>
            <th>Actions</th>
          </tr>
        </thead>
        <tbody>
          {posts.map((p: any) => (
            <tr>
              <td style="font-weight:600;max-width:340px;">
                <div style="overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">{p.title}</div>
                <div style="font-size:0.75rem;opacity:0.45;font-family:monospace;">/blog/{p.slug}</div>
              </td>
              <td><span class={`badge badge-${p.status}`}>{p.status}</span></td>
              <td style="font-size:0.8rem;opacity:0.6;">{p.published_at ? fmtDate(p.published_at) : '—'}</td>
              <td style="font-size:0.8rem;opacity:0.6;">{fmtDate(p.updated_at)}</td>
              <td>
                <div style="display:flex;gap:0.375rem;flex-wrap:wrap;">
                  <a href={`/admin/blog/${p.id}/edit`} class="btn btn-outline btn-sm">Edit</a>
                  {p.status === 'published' && (
                    <a href={`/blog/${p.slug}`} target="_blank" class="btn btn-ghost btn-sm">Preview ↗</a>
                  )}
                  {p.status === 'published' && (
                    <form method="post" style="display:inline;">
                      <input type="hidden" name="action" value="unpublish" />
                      <input type="hidden" name="id" value={p.id} />
                      <button class="btn btn-ghost btn-sm">Unpublish</button>
                    </form>
                  )}
                  <form method="post" onsubmit="return confirm('Delete this post? This cannot be undone.')" style="display:inline;">
                    <input type="hidden" name="action" value="delete" />
                    <input type="hidden" name="id" value={p.id} />
                    <button class="btn btn-danger btn-sm">Delete</button>
                  </form>
                </div>
              </td>
            </tr>
          ))}
        </tbody>
      </table>
    )}
  </div>
</AdminLayout>
