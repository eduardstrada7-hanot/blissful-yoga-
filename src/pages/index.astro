---
import Base from '../layouts/Base.astro';
import ClassCard from '../components/ClassCard.astro';
import TestimonialSlider from '../components/TestimonialSlider.astro';
import EmailSignup from '../components/EmailSignup.astro';
import classes from '../data/classes.json';
---

<Base
  title="Blissful Butterfly Yoga"
  description="Accessible online yoga classes, 1:1 yoga therapy, and trauma-informed community with Veronica Carpenter, C-IAYT, E-RYT 500. Based in Audubon, NJ."
>
  <!-- ═══ HERO ═══ -->
  <section aria-labelledby="hero-heading" style="position:relative;min-height:min(90vh,700px);display:flex;align-items:center;overflow:hidden;background:var(--color-plum);">
    <img
      src="/images/hero.jpg"
      alt="Veronica in a seated yoga pose, sunlight behind her"
      width="1400"
      height="800"
      fetchpriority="high"
      decoding="async"
      style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover;opacity:0.45;"
    />
    <div style="position:absolute;inset:0;background:linear-gradient(100deg,rgba(91,58,91,0.82) 0%,rgba(91,58,91,0.55) 55%,rgba(91,58,91,0.2) 100%);"></div>
    <div class="container" style="position:relative;z-index:1;padding-top:80px;padding-bottom:80px;">
      <div style="max-width:640px;">
        <h1 id="hero-heading" class="hero-h1" style="font-size:clamp(2.4rem,6vw,4rem);font-weight:700;color:var(--color-cream);margin-bottom:1.25rem;line-height:1.1;">
          Yoga therapy for humans carrying hard things.
        </h1>
        <p class="hero-sub" style="font-size:clamp(1rem,2.2vw,1.2rem);color:var(--color-cream);opacity:0.9;margin-bottom:2rem;line-height:1.6;">
          Accessible online classes, 1:1 yoga therapy, and trauma-informed community with Veronica Carpenter, C-IAYT.
        </p>
        <div class="hero-ctas" style="display:flex;flex-wrap:wrap;gap:0.875rem;">
          <a href="/book/discovery-call" class="btn-rose" style="font-size:1rem;padding:0.875rem 2rem;" aria-label="Book a free 20-minute Yoga Therapy Discovery Call">
            Book a free Discovery Call
          </a>
          <a href="/offerings/classes" class="btn-outline" style="font-size:1rem;padding:0.875rem 2rem;" aria-label="See live yoga classes at $15 drop-in">
            Try a $15 live class
          </a>
        </div>
        <p class="hero-trust" style="margin-top:1.5rem;font-size:0.75rem;letter-spacing:0.12em;text-transform:uppercase;color:var(--color-cream);opacity:0.6;font-weight:500;">
          C-IAYT &nbsp;&middot;&nbsp; E-RYT 500 &nbsp;&middot;&nbsp; 2,000+ teaching hours &nbsp;&middot;&nbsp; Audubon, NJ
        </p>
      </div>
    </div>
  </section>

  <hr class="section-divider" />

  <!-- ═══ IS THIS FOR YOU? ═══ -->
  <section class="section-pad" aria-labelledby="for-you-heading">
    <div class="container">
      <h2 id="for-you-heading" class="fade-in" style="text-align:center;font-size:clamp(1.8rem,4vw,2.5rem);margin-bottom:3rem;">Is this for you?</h2>
      <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(260px,1fr));gap:2.5rem;">
        <div class="fade-in" style="text-align:center;padding:0 1rem;">
          <div style="width:56px;height:56px;border-radius:50%;background:rgba(91,58,91,0.1);display:flex;align-items:center;justify-content:center;margin:0 auto 1rem;">
            <svg width="28" height="28" viewBox="0 0 28 28" fill="none" aria-hidden="true"><path d="M14 2a10 10 0 1 0 0 20A10 10 0 0 0 14 2zm0 4a3 3 0 1 1 0 6 3 3 0 0 1 0-6zm0 14c-2.9 0-5.47-1.48-7-3.74.04-2.32 4.67-3.6 7-3.6 2.34 0 6.96 1.28 7 3.6A8.33 8.33 0 0 1 14 20z" fill="var(--color-plum)"/></svg>
          </div>
          <h3 style="font-size:1.3rem;font-weight:700;margin-bottom:0.75rem;">Healing from hard seasons</h3>
          <p style="font-size:0.95rem;line-height:1.7;color:var(--color-ink);opacity:0.75;">Loss, breakups, spiritual injury, burnout — Veronica's practice meets you where you are, no pretense required.</p>
        </div>
        <div class="fade-in" style="text-align:center;padding:0 1rem;">
          <div style="width:56px;height:56px;border-radius:50%;background:rgba(192,132,120,0.1);display:flex;align-items:center;justify-content:center;margin:0 auto 1rem;">
            <svg width="28" height="28" viewBox="0 0 28 28" fill="none" aria-hidden="true"><path d="M14 4a3 3 0 0 1 3 3v5h5a2 2 0 0 1 2 2v9a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2v-9a2 2 0 0 1 2-2h5V7a3 3 0 0 1 3-3z" fill="var(--color-rose)" opacity="0.5"/><circle cx="14" cy="17" r="2" fill="var(--color-rose)"/></svg>
          </div>
          <h3 style="font-size:1.3rem;font-weight:700;margin-bottom:0.75rem;">Yoga that fits a real body</h3>
          <p style="font-size:0.95rem;line-height:1.7;color:var(--color-ink);opacity:0.75;">No pretzel poses. Props, chairs, and modifications are celebrated here. Every body is already a yoga body.</p>
        </div>
        <div class="fade-in" style="text-align:center;padding:0 1rem;">
          <div style="width:56px;height:56px;border-radius:50%;background:rgba(122,138,107,0.1);display:flex;align-items:center;justify-content:center;margin:0 auto 1rem;">
            <svg width="28" height="28" viewBox="0 0 28 28" fill="none" aria-hidden="true"><path d="M14 2L3 8v8c0 6.28 4.5 12.16 11 13.54C20.5 28.16 25 22.28 25 16V8L14 2z" fill="var(--color-sage)" opacity="0.2"/><path d="M14 2L3 8v8c0 6.28 4.5 12.16 11 13.54C20.5 28.16 25 22.28 25 16V8L14 2z" stroke="var(--color-sage)" stroke-width="1.5" stroke-linejoin="round"/></svg>
          </div>
          <h3 style="font-size:1.3rem;font-weight:700;margin-bottom:0.75rem;">A teacher who's been there</h3>
          <p style="font-size:0.95rem;line-height:1.7;color:var(--color-ink);opacity:0.75;">Veronica shares her own journey so you don't have to perform. Authentic, trauma-informed, and deeply human.</p>
        </div>
      </div>
    </div>
  </section>

  <hr class="section-divider" />

  <!-- ═══ YOGA THERAPY FEATURE ═══ -->
  <section class="section-pad" aria-labelledby="therapy-heading" style="background:var(--color-sand);">
    <div class="container" style="display:grid;grid-template-columns:1fr 1fr;gap:4rem;align-items:center;">
      <div class="fade-in">
        <p style="font-size:0.75rem;font-weight:700;letter-spacing:0.12em;text-transform:uppercase;color:var(--color-rose);margin-bottom:0.5rem;">Most popular</p>
        <h2 id="therapy-heading" style="font-size:clamp(2rem,4vw,2.8rem);margin-bottom:1.25rem;">1:1 Yoga Therapy</h2>
        <ul style="list-style:none;padding:0;margin:0 0 1.5rem;display:flex;flex-direction:column;gap:0.75rem;">
          <li style="display:flex;gap:0.75rem;align-items:flex-start;font-size:0.95rem;color:var(--color-ink);line-height:1.6;">
            <svg width="18" height="18" viewBox="0 0 18 18" fill="none" style="flex-shrink:0;margin-top:3px;" aria-hidden="true"><circle cx="9" cy="9" r="8" fill="var(--color-plum)" opacity="0.1"/><path d="M5 9l3 3 5-5" stroke="var(--color-plum)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
            A private session tailored entirely to your body, nervous system, and goals.
          </li>
          <li style="display:flex;gap:0.75rem;align-items:flex-start;font-size:0.95rem;color:var(--color-ink);line-height:1.6;">
            <svg width="18" height="18" viewBox="0 0 18 18" fill="none" style="flex-shrink:0;margin-top:3px;" aria-hidden="true"><circle cx="9" cy="9" r="8" fill="var(--color-plum)" opacity="0.1"/><path d="M5 9l3 3 5-5" stroke="var(--color-plum)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
            Somatic techniques, breathwork, and movement for lasting nervous-system shifts.
          </li>
          <li style="display:flex;gap:0.75rem;align-items:flex-start;font-size:0.95rem;color:var(--color-ink);line-height:1.6;">
            <svg width="18" height="18" viewBox="0 0 18 18" fill="none" style="flex-shrink:0;margin-top:3px;" aria-hidden="true"><circle cx="9" cy="9" r="8" fill="var(--color-plum)" opacity="0.1"/><path d="M5 9l3 3 5-5" stroke="var(--color-plum)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
            Evidence-informed, trauma-sensitive, and deeply compassionate.
          </li>
        </ul>
        <a href="/book/discovery-call" class="btn-primary" aria-label="Book a free 20-minute yoga therapy Discovery Call">
          See if it's a fit — free 20-min call →
        </a>
      </div>
      <div class="fade-in" style="border-radius:16px;overflow:hidden;aspect-ratio:4/5;">
        <img
          src="/images/veronica-portrait.jpg"
          alt="Veronica smiling in a studio"
          width="600"
          height="750"
          loading="lazy"
          decoding="async"
          style="width:100%;height:100%;object-fit:cover;"
        />
      </div>
    </div>
  </section>

  <hr class="section-divider" />

  <!-- ═══ CLASSES PREVIEW ═══ -->
  <section class="section-pad" aria-labelledby="classes-heading">
    <div class="container">
      <div class="fade-in" style="display:flex;align-items:baseline;justify-content:space-between;flex-wrap:wrap;gap:1rem;margin-bottom:1.5rem;">
        <h2 id="classes-heading" style="font-size:clamp(1.8rem,4vw,2.5rem);">This week's live classes</h2>
        <a href="/offerings/classes" style="font-size:0.9rem;font-weight:600;color:var(--color-rose);text-decoration:underline;" aria-label="See the full class schedule">See full schedule →</a>
      </div>
      <p class="fade-in" style="display:inline-flex;align-items:center;font-size:0.85rem;background:var(--color-plum);color:var(--color-cream);padding:0.4rem 1rem;border-radius:4px;margin-bottom:2rem;font-weight:500;">
        New here? Your first class is on me &mdash; use code <strong style="margin:0 0.3em;font-family:monospace;letter-spacing:0.05em;">1FREE</strong> at checkout.
      </p>
      <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(260px,1fr));gap:1.5rem;">
        {classes.map((cls) => (
          <div class="fade-in">
            <ClassCard {...cls} />
          </div>
        ))}
      </div>
    </div>
  </section>

  <hr class="section-divider" />

  <!-- ═══ EMAIL SIGNUP ═══ -->
  <EmailSignup />

  <hr class="section-divider" />

  <!-- ═══ TESTIMONIALS ═══ -->
  <TestimonialSlider />

  <hr class="section-divider" />

  <!-- ═══ ABOUT STRIP ═══ -->
  <section class="section-pad" aria-labelledby="about-strip-heading">
    <div class="container" style="display:grid;grid-template-columns:1fr 1fr;gap:4rem;align-items:center;">
      <div class="fade-in" style="border-radius:16px;overflow:hidden;aspect-ratio:1/1;">
        <img
          src="/images/about-portrait.jpg"
          alt="Portrait of Veronica Carpenter"
          width="600"
          height="600"
          loading="lazy"
          decoding="async"
          style="width:100%;height:100%;object-fit:cover;"
        />
      </div>
      <div class="fade-in">
        <p style="font-size:0.75rem;font-weight:700;letter-spacing:0.12em;text-transform:uppercase;color:var(--color-sage);margin-bottom:0.5rem;">About Veronica</p>
        <h2 id="about-strip-heading" style="font-size:clamp(1.8rem,4vw,2.5rem);margin-bottom:1.25rem;">Hello, I'm Veronica.</h2>
        <p style="font-size:0.975rem;line-height:1.75;color:var(--color-ink);opacity:0.8;margin-bottom:1rem;">
          I'm a Certified Yoga Therapist (C-IAYT) and E-RYT 500 with over 2,000 teaching hours. I trained at Bloomsburg University, completed YTT at Yogaville and advanced training at YogaLife Institute. I believe yoga belongs to everyone — every body, every season of life.
        </p>
        <p style="font-size:0.975rem;line-height:1.75;color:var(--color-ink);opacity:0.8;margin-bottom:1.5rem;">
          My classes are built for real human beings — not performance athletes. Come as you are.
        </p>
        <div style="display:flex;flex-wrap:wrap;gap:0.75rem;">
          <a href="/about" class="btn-primary">Read my full story →</a>
          <a href="/book/discovery-call" class="btn-rose">Book a Discovery Call</a>
        </div>
      </div>
    </div>
  </section>
</Base>

<style>
  @media (max-width: 768px) {
    section[aria-labelledby="therapy-heading"] .container,
    section[aria-labelledby="about-strip-heading"] .container {
      grid-template-columns: 1fr !important;
    }
    section[aria-labelledby="therapy-heading"] .container > div:last-child {
      order: -1;
    }
  }
</style>
