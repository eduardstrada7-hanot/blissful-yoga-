---
import Base from '../layouts/Base.astro';
import EmailSignup from '../components/EmailSignup.astro';
---

<Base
  title="Free Yoga Resources — Root Chakra Mini-Course & Videos"
  description="Start free with Blissful Butterfly Yoga. Get the Root Chakra Mini-Course, free yoga videos, and Veronica's Spotify playlist. No credit card needed."
>
  <section style="padding:80px 0 0;background:var(--color-sand);">
    <div class="container" style="max-width:800px;padding-bottom:80px;">
      <p style="font-size:0.75rem;font-weight:700;letter-spacing:0.12em;text-transform:uppercase;color:var(--color-rose);margin-bottom:0.5rem;" class="fade-in">No credit card needed</p>
      <h1 style="font-size:clamp(2.2rem,5vw,3rem);margin-bottom:1rem;" class="fade-in">Free resources</h1>
      <p style="font-size:1.05rem;line-height:1.75;color:var(--color-ink);opacity:0.8;margin-bottom:3rem;" class="fade-in">
        Not sure yet? Start here. Everything below is free — no obligation, no credit card, no catch.
      </p>

      <div style="display:flex;flex-direction:column;gap:1.5rem;">
        <div class="fade-in" style="background:var(--color-cream);border:1px solid var(--color-line);border-radius:4px;padding:2rem;display:flex;gap:1.5rem;align-items:flex-start;">
          <div style="width:48px;height:48px;border-radius:50%;background:rgba(91,58,91,0.1);display:flex;align-items:center;justify-content:center;flex-shrink:0;">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M12 2a5 5 0 1 1 0 10A5 5 0 0 1 12 2zm0 12c-5.33 0-8 2.67-8 4v2h16v-2c0-1.33-2.67-4-8-4z" fill="var(--color-plum)"/></svg>
          </div>
          <div>
            <h2 style="font-size:1.25rem;margin:0 0 0.5rem;">Root Chakra Mini-Course</h2>
            <p style="font-size:0.9rem;line-height:1.7;color:var(--color-ink);opacity:0.75;margin:0 0 1rem;">5 short grounding practices delivered to your inbox. Breath, movement, and stillness for when life feels unsteady. Sign up below.</p>
            <a href="#email-signup-heading" class="btn-primary" style="font-size:0.875rem;padding:0.5rem 1.25rem;">Get the mini-course →</a>
          </div>
        </div>

        <div class="fade-in" style="background:var(--color-cream);border:1px solid var(--color-line);border-radius:4px;padding:2rem;display:flex;gap:1.5rem;align-items:flex-start;">
          <div style="width:48px;height:48px;border-radius:50%;background:rgba(192,132,120,0.1);display:flex;align-items:center;justify-content:center;flex-shrink:0;">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true"><circle cx="12" cy="12" r="9" stroke="var(--color-rose)" stroke-width="1.5"/><polygon points="10,8 17,12 10,16" fill="var(--color-rose)"/></svg>
          </div>
          <div>
            <h2 style="font-size:1.25rem;margin:0 0 0.5rem;">Free Videos on YouTube</h2>
            <p style="font-size:0.9rem;line-height:1.7;color:var(--color-ink);opacity:0.75;margin:0 0 1rem;">Short practices, class previews, and teaching clips from Veronica's YouTube channel.</p>
            <a href="https://www.youtube.com/channel/UCYbDbaAc1tHfPldC4uy-TWQ" target="_blank" rel="noopener noreferrer" class="btn-rose" style="font-size:0.875rem;padding:0.5rem 1.25rem;">Watch on YouTube →</a>
          </div>
        </div>

        <div class="fade-in" style="background:var(--color-cream);border:1px solid var(--color-line);border-radius:4px;padding:2rem;display:flex;gap:1.5rem;align-items:flex-start;">
          <div style="width:48px;height:48px;border-radius:50%;background:rgba(122,138,107,0.1);display:flex;align-items:center;justify-content:center;flex-shrink:0;">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true"><circle cx="12" cy="12" r="9" stroke="var(--color-sage)" stroke-width="1.5"/><path d="M8 14.5a4 4 0 0 1 8 0M7 11a6 6 0 0 1 10 0M9 17.5a2 2 0 0 1 6 0" stroke="var(--color-sage)" stroke-width="1.5" stroke-linecap="round" fill="none"/></svg>
          </div>
          <div>
            <h2 style="font-size:1.25rem;margin:0 0 0.5rem;">Veronica's Spotify Playlist</h2>
            <p style="font-size:0.9rem;line-height:1.7;color:var(--color-ink);opacity:0.75;margin:0 0 1rem;">The music Veronica curates for her classes — grounding, gentle, and perfect for home practice.</p>
            <a href="https://open.spotify.com/user/12132290196" target="_blank" rel="noopener noreferrer" style="display:inline-flex;align-items:center;padding:0.5rem 1.25rem;background:var(--color-sage);color:#fff;border-radius:4px;font-size:0.875rem;font-weight:600;text-decoration:none;transition:filter 150ms ease;" onmouseover="this.style.filter='brightness(0.85)'" onmouseout="this.style.filter='none'">Listen on Spotify →</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <hr class="section-divider" />

  <EmailSignup />
</Base>
