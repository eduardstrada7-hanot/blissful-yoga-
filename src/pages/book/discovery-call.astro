---
import Base from '../../layouts/Base.astro';
---

<Base
  title="Book a Free Yoga Therapy Discovery Call"
  description="Schedule your free 20-minute Discovery Call with Veronica Carpenter, C-IAYT. Find out if 1:1 yoga therapy is right for you — no pressure, no commitment."
>
  <section style="padding:80px 0;background:var(--color-sand);">
    <div class="container" style="max-width:760px;">
      <p style="font-size:0.75rem;font-weight:700;letter-spacing:0.12em;text-transform:uppercase;color:var(--color-rose);margin-bottom:0.5rem;" class="fade-in">Free · 20 minutes · Zoom</p>
      <h1 style="font-size:clamp(2.2rem,5vw,3rem);margin-bottom:1rem;" class="fade-in">Book Your Discovery Call</h1>
      <p style="font-size:1.05rem;line-height:1.75;color:var(--color-ink);opacity:0.8;max-width:560px;margin-bottom:2.5rem;" class="fade-in">
        A free 20-minute conversation with Veronica. You'll share what you're dealing with, she'll ask a few questions, and together you'll decide if yoga therapy is the right next step. No pressure. No sales pitch.
      </p>

      <!-- Calendar embed placeholder -->
      <div class="fade-in" style="background:var(--color-cream);border:1px solid var(--color-line);border-radius:4px;padding:3rem;text-align:center;min-height:400px;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:1rem;">
        <svg width="48" height="48" viewBox="0 0 48 48" fill="none" aria-hidden="true"><rect x="6" y="10" width="36" height="32" rx="3" stroke="var(--color-plum)" stroke-width="2"/><path d="M6 18h36" stroke="var(--color-plum)" stroke-width="2"/><path d="M16 6v6M32 6v6" stroke="var(--color-plum)" stroke-width="2" stroke-linecap="round"/><rect x="13" y="24" width="6" height="5" rx="1" fill="var(--color-plum)" opacity="0.3"/><rect x="22" y="24" width="6" height="5" rx="1" fill="var(--color-plum)" opacity="0.3"/></svg>
        <p style="font-size:1.05rem;font-weight:600;color:var(--color-plum);">Calendar coming soon</p>
        <p style="font-size:0.9rem;color:var(--color-ink);opacity:0.65;max-width:400px;line-height:1.6;">In the meantime, email Veronica directly to schedule your call:</p>
        <a href="mailto:veronica@blissfulbutterflyyoga.com?subject=Discovery Call Request" class="btn-primary">
          Email Veronica →
        </a>
        <p style="font-size:0.8rem;color:var(--color-ink);opacity:0.5;font-style:italic;">She typically responds within 24 hours.</p>
      </div>

      <!-- What to expect -->
      <div style="margin-top:3rem;" class="fade-in">
        <h2 style="font-size:1.4rem;margin-bottom:1.25rem;">What happens on the call?</h2>
        <div style="display:flex;flex-direction:column;gap:1rem;">
          {[
            ["You share", "Tell Veronica what you're carrying — what's brought you here, what you've tried, what you're hoping for."],
            ["She listens", "No intake forms before the call. Just a real conversation."],
            ["Honest assessment", "Veronica will tell you directly whether yoga therapy is a good fit, and what she'd recommend."],
            ["No pressure", "If it's not the right fit, she'll say so and point you toward something that is."],
          ].map(([label, text]) => (
            <div style="display:flex;gap:1rem;align-items:flex-start;padding:1rem;background:var(--color-cream);border-radius:4px;border:1px solid var(--color-line);">
              <span style="font-family:var(--font-display);font-size:1rem;font-weight:700;color:var(--color-plum);white-space:nowrap;">{label}</span>
              <p style="font-size:0.9rem;line-height:1.6;color:var(--color-ink);opacity:0.75;margin:0;">{text}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>
</Base>
