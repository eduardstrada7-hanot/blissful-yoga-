---
import Base from '../layouts/Base.astro';
---

<Base
  title="Yoga On Demand — Members-Only Class Library"
  description="Access Veronica Carpenter's library of recorded yoga classes any time. Gentle, Yin, Vin Yin, and more — available to members 24/7."
>
  <section style="padding:80px 0;background:var(--color-sand);">
    <div class="container" style="max-width:760px;text-align:center;">
      <p style="font-size:0.75rem;font-weight:700;letter-spacing:0.12em;text-transform:uppercase;color:var(--color-rose);margin-bottom:0.5rem;" class="fade-in">Members only</p>
      <h1 style="font-size:clamp(2.2rem,5vw,3rem);margin-bottom:1rem;" class="fade-in">Yoga On Demand</h1>
      <p style="font-size:1.05rem;line-height:1.75;color:var(--color-ink);opacity:0.8;max-width:560px;margin:0 auto 2.5rem;" class="fade-in">
        A growing library of recorded classes available to members any time. Practice at your pace, on your schedule.
      </p>

      <div class="fade-in" style="padding:3rem;background:var(--color-plum);border-radius:4px;color:var(--color-cream);margin-bottom:2rem;">
        <svg width="56" height="56" viewBox="0 0 56 56" fill="none" style="margin:0 auto 1.25rem;" aria-hidden="true"><rect x="6" y="12" width="44" height="32" rx="4" stroke="var(--color-cream)" stroke-width="2" opacity="0.5"/><polygon points="22,20 38,28 22,36" fill="var(--color-cream)"/></svg>
        <h2 style="color:var(--color-cream);margin-bottom:0.75rem;font-size:clamp(1.4rem,3vw,1.8rem);">Coming soon</h2>
        <p style="opacity:0.85;margin-bottom:1.5rem;line-height:1.7;">The On Demand library is being built. Join the email list to be notified when it launches.</p>
        <a href="/free" class="btn-outline">Get notified →</a>
      </div>

      <p class="fade-in" style="font-size:0.9rem;color:var(--color-ink);opacity:0.65;">
        In the meantime, <a href="/offerings/classes" style="color:var(--color-rose);font-weight:600;text-decoration:underline;">join a live class</a> — same great teaching, real-time connection.
      </p>
    </div>
  </section>
</Base>
