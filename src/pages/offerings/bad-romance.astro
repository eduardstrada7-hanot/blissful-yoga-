---
import Base from '../../layouts/Base.astro';
---

<Base
  title="Bad Romance Recovery — Healing From Relationship Loss"
  description="Bad Romance Recovery with Veronica Carpenter — a structured program for women healing from toxic relationships, heartbreak, and relationship patterns."
>
  <section style="padding:80px 0;background:var(--color-sand);">
    <div class="container" style="max-width:760px;">
      <p style="font-size:0.75rem;font-weight:700;letter-spacing:0.12em;text-transform:uppercase;color:var(--color-rose);margin-bottom:0.5rem;" class="fade-in">Healing program</p>
      <h1 style="font-size:clamp(2.2rem,5vw,3rem);margin-bottom:1rem;" class="fade-in">Bad Romance Recovery</h1>
      <p style="font-size:1.1rem;line-height:1.75;color:var(--color-ink);opacity:0.8;max-width:580px;margin-bottom:2.5rem;" class="fade-in">
        For women who have loved hard, been hurt, and are ready — on their own terms, in their own time — to find their way back to themselves.
      </p>

      <div style="display:flex;flex-direction:column;gap:1.5rem;margin-bottom:3rem;">
        {[
          { label: "What it is", body: "A structured healing program that uses yoga, breathwork, somatic movement, journaling, and community to support recovery from toxic relationships, heartbreak, and dysfunctional relationship patterns." },
          { label: "Who it's for", body: "Women who are healing from a breakup, divorce, emotional abuse, or repeated relationship patterns. Wherever you are in that process — raw grief or quiet rebuilding — there's room for you here." },
          { label: "What's included", body: "A combination of live group sessions, recorded practices, guided reflection prompts, and a private community of women on the same path." },
          { label: "Pricing & next cohort", body: "Pricing and dates for the next cohort are available by inquiry. Veronica personally reviews every application." },
        ].map(({ label, body }) => (
          <div class="fade-in" style="padding:1.5rem;background:var(--color-cream);border:1px solid var(--color-line);border-radius:4px;">
            <p style="font-size:0.75rem;font-weight:700;letter-spacing:0.1em;text-transform:uppercase;color:var(--color-sage);margin:0 0 0.5rem;">{label}</p>
            <p style="font-size:0.95rem;line-height:1.7;color:var(--color-ink);margin:0;">{body}</p>
          </div>
        ))}
      </div>

      <div class="fade-in" style="text-align:center;padding:2.5rem;background:var(--color-plum);border-radius:4px;color:var(--color-cream);">
        <h2 style="color:var(--color-cream);margin-bottom:0.75rem;">Inquire about the program</h2>
        <p style="opacity:0.85;margin-bottom:1.5rem;">Reach out to Veronica to learn about the next cohort and whether this program is right for you.</p>
        <a href={`mailto:veronica@blissfulbutterflyyoga.com?subject=Bad Romance Recovery Inquiry`} class="btn-outline">
          Email Veronica →
        </a>
      </div>
    </div>
  </section>
</Base>
