---
import Base from '../../layouts/Base.astro';
---

<Base
  title="Special Events — Workshops, Retreats & Ecstatic Dance"
  description="Special events from Blissful Butterfly Yoga — yoga workshops, wellness retreats, and Ecstatic Dance gatherings with Veronica Carpenter."
>
  <section style="padding:80px 0;background:var(--color-sand);">
    <div class="container" style="max-width:760px;">
      <p style="font-size:0.75rem;font-weight:700;letter-spacing:0.12em;text-transform:uppercase;color:var(--color-gold);margin-bottom:0.5rem;" class="fade-in">Seasonal & special</p>
      <h1 style="font-size:clamp(2.2rem,5vw,3rem);margin-bottom:1rem;" class="fade-in">Special Events</h1>
      <p style="font-size:1.1rem;line-height:1.75;color:var(--color-ink);opacity:0.8;max-width:580px;margin-bottom:2.5rem;" class="fade-in">
        Workshops, mini-retreats, and Ecstatic Dance — deeper dives for when you're ready to go beyond the weekly class.
      </p>

      <div style="padding:2rem;background:var(--color-cream);border:1px solid var(--color-line);border-radius:4px;text-align:center;" class="fade-in">
        <p style="font-family:var(--font-display);font-size:1.2rem;font-style:italic;color:var(--color-plum);margin-bottom:1rem;">No events currently scheduled.</p>
        <p style="font-size:0.9rem;color:var(--color-ink);opacity:0.7;margin-bottom:1.5rem;">Join the email list to be the first to hear about upcoming workshops, retreats, and Ecstatic Dance dates.</p>
        <a href="/free#email-signup-heading" class="btn-primary">Join the email list →</a>
      </div>
    </div>
  </section>
</Base>
