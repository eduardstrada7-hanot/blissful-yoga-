---
import Base from '../../layouts/Base.astro';
import FAQ from '../../components/FAQ.astro';

const faqs = [
  {
    q: "Do I need any yoga experience?",
    a: "None at all. This journey is entirely non-verbal and movement-based — no poses to learn, no experience needed. Your body already knows the way.",
  },
  {
    q: "What should I wear?",
    a: "Comfortable, loose clothing you can move freely in. You'll be on a mat, on the floor, and moving in ways that may feel unfamiliar — dress for ease.",
  },
  {
    q: "Is this therapy?",
    a: "Inner Child Yoga is a somatic and movement-based experience, not psychotherapy. It can surface emotions, and Veronica holds the space with care. If you are currently working with a therapist, this can be a powerful complement to that work.",
  },
  {
    q: "Can I attend if I have trauma?",
    a: "Yes. Veronica is trauma-informed and leads this experience with that awareness. You are always invited — never required — to go deeper. You set the pace.",
  },
  {
    q: "Is this offered online or in person?",
    a: "Currently offered online via Zoom. You'll need a mat and enough floor space to stretch out fully in all directions.",
  },
];
---

<Base
  title="Inner Child Yoga — A Journey From Embryo to Walking"
  description="Inner Child Yoga with Veronica Carpenter — a somatic movement experience that guides you through the developmental stages of life, from embryo to first steps. Heal, remember, and return to yourself."
>
  <!-- Hero -->
  <section style="background:var(--color-plum);padding:80px 0;position:relative;overflow:hidden;">
    <div style="position:absolute;inset:0;opacity:0.06;background:radial-gradient(circle at 30% 50%, var(--color-gold) 0%, transparent 60%), radial-gradient(circle at 80% 20%, var(--color-rose) 0%, transparent 50%);"></div>
    <div class="container" style="position:relative;z-index:1;max-width:760px;">
      <p style="font-size:0.75rem;font-weight:700;letter-spacing:0.12em;text-transform:uppercase;color:var(--color-rose);margin-bottom:0.5rem;" class="fade-in">Somatic movement experience</p>
      <h1 style="font-size:clamp(2.4rem,6vw,3.5rem);color:var(--color-cream);margin-bottom:1.25rem;line-height:1.1;" class="fade-in">Inner Child Yoga</h1>
      <p style="font-size:clamp(1rem,2.2vw,1.2rem);color:var(--color-cream);opacity:0.85;max-width:580px;line-height:1.7;margin-bottom:2rem;" class="fade-in">
        A guided movement journey through the earliest experiences of being human — from the curled stillness of the womb, through rolling and crawling, all the way to standing and your first steps.
      </p>
      <a href="/contact" class="btn-outline" style="font-size:1rem;padding:0.875rem 2rem;" class="fade-in">
        Inquire about upcoming dates →
      </a>
    </div>
  </section>

  <hr class="section-divider" />

  <!-- What it is -->
  <section class="section-pad" aria-labelledby="what-heading">
    <div class="container" style="display:grid;grid-template-columns:1fr 1fr;gap:4rem;align-items:center;">
      <div class="fade-in">
        <p style="font-size:0.75rem;font-weight:700;letter-spacing:0.12em;text-transform:uppercase;color:var(--color-rose);margin-bottom:0.5rem;">The experience</p>
        <h2 id="what-heading" style="font-size:clamp(1.8rem,4vw,2.5rem);margin-bottom:1.25rem;">What is Inner Child Yoga?</h2>
        <p style="font-size:1rem;line-height:1.8;color:var(--color-ink);margin-bottom:1rem;">
          Inner Child Yoga is a slow, guided somatic journey that moves through the developmental stages every human body travels in its first year of life — from embryo, to newborn, through rolling, sitting, crawling, and finally standing and walking.
        </p>
        <p style="font-size:1rem;line-height:1.8;color:var(--color-ink);margin-bottom:1rem;">
          These movements are stored deep in the body's memory. Revisiting them — with breath, awareness, and gentleness — can unlock places we've held tension for years without knowing why. It's not about going back to childhood emotionally. It's about letting the body remember what it already knows.
        </p>
        <p style="font-size:1rem;line-height:1.8;color:var(--color-ink);">
          Veronica guides the entire journey with music, breath cues, and gentle invitations. There is no right or wrong way to move. You follow your body.
        </p>
      </div>

      <!-- Journey stages visual -->
      <div class="fade-in" style="display:flex;flex-direction:column;gap:1rem;">
        {[
          { stage: "Embryo", desc: "Curled, floating, held. The first knowing of being." },
          { stage: "Newborn", desc: "Breath arriving. Limbs discovering. The world as sensation." },
          { stage: "Rolling", desc: "Learning to turn toward and away. The first choice." },
          { stage: "Sitting", desc: "Finding center. The spine rising. The world from a new vantage." },
          { stage: "Crawling", desc: "Cross-lateral movement. Left and right brain in conversation." },
          { stage: "Standing", desc: "Rising. Finding ground beneath the feet." },
          { stage: "Walking", desc: "Moving through the world. Upright, present, free." },
        ].map(({ stage, desc }, i) => (
          <div style="display:flex;gap:1rem;align-items:flex-start;padding:0.875rem 1rem;background:var(--color-cream);border:1px solid var(--color-line);border-radius:4px;">
            <span style={`font-family:var(--font-display);font-size:1.5rem;font-weight:700;color:var(--color-plum);opacity:${0.2 + i * 0.12};flex-shrink:0;min-width:1.5rem;line-height:1;`}>{i + 1}</span>
            <div>
              <p style="font-weight:700;color:var(--color-plum);margin:0 0 0.2rem;font-size:0.95rem;">{stage}</p>
              <p style="font-size:0.85rem;color:var(--color-ink);opacity:0.7;margin:0;line-height:1.5;">{desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <hr class="section-divider" />

  <!-- Who it's for -->
  <section class="section-pad" style="background:var(--color-sand);" aria-labelledby="for-heading">
    <div class="container" style="max-width:800px;">
      <h2 id="for-heading" style="font-size:clamp(1.8rem,3.5vw,2.4rem);margin-bottom:1.5rem;" class="fade-in">Who this is for</h2>
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:1rem;" class="fade-in">
        {[
          "Anyone who feels disconnected from their body",
          "People carrying early trauma or adverse childhood experiences",
          "Those curious about somatic and developmental movement",
          "Anyone who wants to play, slow down, and feel more alive",
          "People in grief or major life transition",
          "Yoga students wanting to deepen their practice",
          "Those healing from chronic stress or burnout",
          "Anyone who was told to 'grow up' too fast",
        ].map((item) => (
          <div style="display:flex;gap:0.75rem;align-items:flex-start;padding:0.75rem;background:var(--color-cream);border:1px solid var(--color-line);border-radius:4px;">
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none" style="flex-shrink:0;margin-top:2px;" aria-hidden="true"><circle cx="8" cy="8" r="7" fill="var(--color-plum)" opacity="0.12"/><path d="M4.5 8l2.5 2.5 4.5-4.5" stroke="var(--color-plum)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            <span style="font-size:0.9rem;line-height:1.5;color:var(--color-ink);">{item}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <hr class="section-divider" />

  <!-- Pull quote -->
  <section style="padding:80px 0;background:var(--color-cream);">
    <div class="container" style="max-width:680px;text-align:center;">
      <blockquote class="fade-in" style="margin:0;">
        <svg width="36" height="28" viewBox="0 0 36 28" fill="none" style="margin:0 auto 1.25rem;" aria-hidden="true">
          <path d="M0 28V16.8C0 10.08 3.6 4.48 10.8 0L14 3.73c-4.27 2.61-6.53 5.97-6.53 10.27H14V28H0zm22 0V16.8C22 10.08 25.6 4.48 32.8 0L36 3.73c-4.27 2.61-6.53 5.97-6.53 10.27H36V28H22z" fill="var(--color-plum)" opacity="0.2"/>
        </svg>
        <p style="font-family:var(--font-display);font-size:clamp(1.2rem,3vw,1.6rem);font-style:italic;line-height:1.65;color:var(--color-plum);margin-bottom:1rem;">
          "The body remembers what the mind has forgotten. When we move the way we first moved, something old and wise wakes up."
        </p>
        <cite style="font-family:var(--font-hand);font-size:1.1rem;font-style:normal;color:var(--color-ink);opacity:0.65;">— Veronica Carpenter</cite>
      </blockquote>
    </div>
  </section>

  <hr class="section-divider" />

  <!-- CTA -->
  <section class="section-pad">
    <div class="container" style="max-width:680px;text-align:center;">
      <div class="fade-in" style="padding:3rem;background:var(--color-plum);border-radius:4px;color:var(--color-cream);">
        <h2 style="color:var(--color-cream);font-size:clamp(1.6rem,3vw,2.2rem);margin-bottom:0.75rem;">Ready to come home to yourself?</h2>
        <p style="opacity:0.85;line-height:1.7;margin-bottom:1.75rem;">Reach out to ask about upcoming Inner Child Yoga sessions — individual or group.</p>
        <a href="/contact" class="btn-outline" style="font-size:1rem;padding:0.875rem 2.5rem;">
          Get in touch →
        </a>
      </div>
    </div>
  </section>

  <hr class="section-divider" />

  <FAQ items={faqs} heading="Questions about Inner Child Yoga" />

  <style>
    @media (max-width: 768px) {
      section[aria-labelledby="what-heading"] .container,
      section[aria-labelledby="for-heading"] .container > div[style*="grid-template-columns:1fr 1fr"] {
        grid-template-columns: 1fr !important;
      }
    }
  </style>
</Base>
